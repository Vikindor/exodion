{
  "manifest_version": 3,
  "name": "Exodion",
  "version": "2.0.0",

  "description": "Shows Exodus Privacy tracker numbers for Android apps on Google Play.",

  "browser_specific_settings": {
    "gecko": {
      "id": "exodion@vikindor.github.io",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "icons": {
    "48": "icons/exodion-48.png"
  },

  "background": {
    "scripts": ["browser-polyfill.js","ep-api.js","background.js"]
  },

  "permissions" : [
    "storage",
    "activeTab"
  ],

  "host_permissions": [
    "*://play.google.com/*",
    "https://reports.exodus-privacy.eu.org/api/search/*",
    "https://reports.exodus-privacy.eu.org/api/trackers*",
    "*://reports.exodus-privacy.eu.org/*/analysis/submit/*"
  ],

  "options_ui": {
      "page": "settings/options.html"
  },

  "content_scripts": [
    {
      "matches": ["*://play.google.com/*"],
      "js": ["browser-polyfill.js","ep-api.js","exodion.js"],
      "css" : ["exodion.css"]
    },
    {
      "matches": ["*://reports.exodus-privacy.eu.org/*/analysis/submit/*"],
      "js": ["exodion-sub.js"]
    }
  ],

  "action": {
    "default_icon": "icons/exodion-32.png",
    "default_title": "Exodion",
    "default_popup": "popup/exodion_pop.html"
  }
}
