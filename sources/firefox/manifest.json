{
  "manifest_version": 3,
  "name": "Exodion",
  "version": "1.5.0",
  "description": "Shows Exodus Privacy tracker numbers for Android apps on Google Play",
  "icons": {
    "32": "icons/exodion-32.png",
    "48": "icons/exodion-48.png"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "*://play.google.com/*",
    "https://reports.exodus-privacy.eu.org/api/search/*",
    "https://reports.exodus-privacy.eu.org/api/trackers*",
    "*://reports.exodus-privacy.eu.org/*/analysis/submit/*"
  ],
  "background": {
    "scripts": [
      "browser-polyfill.js",
      "ep-api.js",
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "*://play.google.com/*"
      ],
      "js": [
        "browser-polyfill.js",
        "ep-api.js",
        "exodion.js"
      ],
      "css": [
        "exodion.css"
      ]
    },
    {
      "matches": [
        "*://reports.exodus-privacy.eu.org/*/analysis/submit/*"
      ],
      "js": [
        "exodion-sub.js"
      ]
    }
  ],
  "action": {
    "default_title": "Exodion",
    "default_icon": {
      "32": "icons/exodion-32.png",
      "48": "icons/exodion-48.png"
    },
    "default_popup": "popup/exodion_pop.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "exodion@vikindor.github.io",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
